# Example deployment config for memory-lancedb-pro-backend.
# This file documents the current deployment shape for the Rust backend service.
# Keep keys aligned with backend/src/config.rs.

[server]
bind = "0.0.0.0:8080"

[storage]
lancedb_path = "/var/lib/memory-lancedb-pro-backend/lancedb"
sqlite_path = "/var/lib/memory-lancedb-pro-backend/sqlite/jobs.db"

[auth.runtime]
token = "replace-with-runtime-bearer-token"

[auth.admin]
token = "replace-with-admin-bearer-token"

[logging]
level = "info"

[providers.embedding]
base_url = "https://api.openai.com/v1"
model = "text-embedding-3-small"
api = "openai"
api_key = "replace-with-embedding-api-key"

[providers.rerank]
enabled = false
