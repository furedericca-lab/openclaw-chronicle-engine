# Example deployment config for Chronicle Engine backend containers.
# This file documents the current deployment shape for the Rust backend service.
# Keep keys aligned with backend/src/config.rs.
# Docker deployments bake this file into the image by default.
# Override keys with CHRONICLE_<TABLE>__<SUBTABLE>__<KEY> environment variables.

[server]
bind = "0.0.0.0:8080"
admin_assets_path = "/usr/local/bin/web/dist"

[storage]
lancedb_path = "/var/lib/chronicle-engine-backend/lancedb"
sqlite_path = "/var/lib/chronicle-engine-backend/sqlite/jobs.db"

[auth.runtime]
token = "replace-with-runtime-bearer-token"

[auth.admin]
token = "replace-with-admin-bearer-token"

[logging]
level = "info"

[providers.embedding]
base_url = "https://api.openai.com/v1"
model = "text-embedding-3-small"
api = "openai"
api_key = "replace-with-embedding-api-key"

[providers.rerank]
enabled = false
